{
  "name": "yandex-music-web",
  "version": "1.0.0",
  "description": "Yandex Music browser downloader",
  "main": "electron.js",
  "scripts": {
    "start": "node server.js",
    "electron": "electron .",
    "build": "electron-builder --win"
  },
  "dependencies": {
    "express": "^4.18.0"
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.yandex-music-downloader",
    "productName": "Yandex Music Downloader",
    "copyright": "Not affiliated with Yandex",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron.js",
      "server.js",
      "public/**/*",
      "package.json",
      "node_modules/**/*",
      "!node_modules/electron/**/*",
      "!node_modules/electron-builder/**/*"
    ],
    "win": {
      "target": [
        { "target": "zip", "arch": ["x64"] }
      ],
      "forceCodeSigning": false
    }
  }
}
